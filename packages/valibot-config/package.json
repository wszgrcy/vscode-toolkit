{
  "name": "@cyia/vscode-valibot-config",
  "version": "1.0.0",
  "description": "VSCode configuration manager based on Valibot schemas",
  "author": "wszgrcy",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "test:build": "rimraf -g ./test-dist && tsx ./script/test.esbuild.ts",
    "test": "rimraf -g ./test-dist && tsx ./script/test.esbuild.ts && vscode-test",
    "coverage": "rimraf -g ./test-dist && tsx ./script/test.esbuild.ts && vscode-test --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wszgrcy/vscode-toolkit",
    "directory": "packages/valibot-config"
  },
  "homepage": "https://github.com/wszgrcy/vscode-toolkit/tree/main/packages/valibot-config#readme",
  "bugs": {
    "url": "https://github.com/wszgrcy/vscode-toolkit/issues"
  },
  "keywords": [
    "vscode",
    "configuration",
    "valibot",
    "schema",
    "extension",
    "settings",
    "reactive"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./valibot-to-vscode-config": {
      "types": "./valibot-to-vscode-config.d.ts",
      "import": "./valibot-to-vscode-config.mjs"
    }
  },
  "dependencies": {
    "valibot": "^1.3.1",
    "fast-equals": "^6.0.0",
    "@piying/valibot-visit": "^1.3.8",
    "static-injector": "^6.3.1",
    "rfdc": "^1.4.1",
    "es-toolkit": "^1.46.0",
    "@valibot/to-json-schema": "^1.6.0"
  }
}
