{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "../../",
    "lib": [
      "ES2020",
      "dom"
    ],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "vscode"
    ]
  },
  "include": [
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}