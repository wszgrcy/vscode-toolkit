    "@vscode/test-electron": "^2.5.2",
    "debug": "4.4.1",
    "es-toolkit": "^1.46.0",
    "fast-equals": "^6.0.0",
    "rfdc": "^1.4.1",
    "rxjs": "^7.8.2",
    "snappyjs": "^0.7.0",
    "static-injector": "^6.3.1",
    "valibot": "^1.3.1"
