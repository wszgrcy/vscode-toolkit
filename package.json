  "repository": {
    "type": "git",
    "url": "https://github.com/wszgrcy/vscode-toolkit"
  },
  "scripts": {
    "test": "pnpm -r --if-present test",
    "build": "rimraf ./dist && tsx ./script/build.esbuild.ts && tsc -P ./tsconfig.type.json ",
    "coverage": "pnpm -r --if-present coverage",
    "lint": "eslint --fix ./packages/**/*.ts && prettier ./packages/**/*.ts --write",
    "publish-only": "tsx ./script/publish.ts"
  },
  "author": "wszgrcy",
  "license": "ISC",
  "description": "A collection of utilities designed for VS Code extension development",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.11",
    "@types/snappyjs": "^0.7.1",
    "@types/vscode": "^1.95.0",
    "c8": "^10.1.3",
    "chai": "^6.2.0",
    "esbuild": "^0.28.0",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "globals": "^16.0.0",
    "mocha": "^11.7.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
